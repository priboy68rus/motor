<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ manifest.report.title }}</title>
  <style>
    :root { color-scheme: light; font-family: Inter, system-ui, sans-serif; color: #172033; background: #f6f7f9; }
    body { margin: 0; }
    main { max-width: 1120px; margin: 0 auto; padding: 48px 24px; }
    h1 { font-size: 2rem; margin: 0 0 24px; }
    h2 { font-size: 1rem; margin: 0 0 16px; }
    .motor-card { background: white; border: 1px solid #dce1e8; border-radius: 12px; padding: 20px; margin: 16px 0; box-shadow: 0 2px 8px #1720330a; overflow-x: auto; }
    .motor-component { position: relative; transition: opacity .15s ease; }
    .motor-component-error, .motor-fatal-error { color: #a11b1b; background: #fff4f4; border: 1px solid #f2b8b8; border-radius: 12px; padding: 20px; }
    .motor-version { color: #667085; font-family: ui-monospace, monospace; font-size: .8rem; margin: 12px 0; overflow-wrap: anywhere; }
    .motor-data-status { display: grid; gap: 6px; color: #667085; font-size: .82rem; margin: 12px 0; overflow-wrap: anywhere; }
    .motor-data-status-summary, .motor-data-source { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 12px; }
    .motor-data-status-sources { display: grid; gap: 4px; }
    .motor-data-status-state { border: 1px solid #abefc6; border-radius: 999px; padding: 2px 8px; background: #ecfdf3; color: #067647; font-weight: 650; }
    .motor-data-status-state.warning { border-color: #f5d08a; background: #fff7e6; color: #8a5700; }
    .motor-data-source.warning .motor-data-source-name { color: #8a5700; }
    .motor-data-source-name { color: #344054; font-weight: 650; }
    .motor-data-status-item { display: inline-flex; align-items: baseline; gap: 4px; }
    .motor-data-status-label { color: #98a2b3; }
    .motor-data-status-value { color: #475467; font-variant-numeric: tabular-nums; }
    .motor-loading-metrics { display: grid; gap: 6px; color: #667085; font-size: .82rem; margin: 12px 0; overflow-wrap: anywhere; }
    .motor-loading-metrics-summary { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 12px; }
    .motor-loading-metrics-state { border: 1px solid #b2ccff; border-radius: 999px; padding: 2px 8px; background: #eff4ff; color: #3538cd; font-weight: 650; }
    .motor-loading-metrics-state.done { border-color: #abefc6; background: #ecfdf3; color: #067647; }
    .motor-loading-metrics-table { width: auto; max-width: 100%; border-collapse: collapse; }
    .motor-loading-metrics-table th, .motor-loading-metrics-table td { border: 0; padding: 3px 12px 3px 0; color: #667085; font-size: .82rem; line-height: 1.35; text-align: left; text-transform: none; vertical-align: top; }
    .motor-loading-metrics-table th { color: #98a2b3; font-weight: 650; }
    .motor-loading-metrics-table .motor-loading-metrics-label { color: #475467; }
    .motor-loading-metrics-table .motor-loading-metrics-duration { color: #344054; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .motor-loading-metrics-table .motor-loading-metrics-detail { color: #667085; }
    .motor-loading-metrics-table tr.is-failed td { color: #b42318; }
    .motor-big-value { font-size: 2.25rem; font-weight: 700; }
    .motor-big-value-comparison { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; color: #667085; font-weight: 650; }
    .motor-big-value-comparison.good { color: #067647; }
    .motor-big-value-comparison.bad { color: #b42318; }
    .motor-big-value-delta-separator { color: #98a2b3; }
    .motor-big-value-delta-label { margin: 4px 0 0; color: #667085; font-size: .82rem; }
    .motor-empty { color: #667085; margin: 0; }
    .motor-filters { overflow: visible; }
    .motor-filter-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin: 0 0 16px; }
    .motor-filter-header h2 { margin: 0; }
    .motor-filter-reset { appearance: none; border: 1px solid #cbd2dc; border-radius: 999px; padding: 4px 10px; background: white; color: #475467; cursor: pointer; font: inherit; font-size: .78rem; font-weight: 650; line-height: 1.4; white-space: nowrap; }
    .motor-filter-reset:hover:not(:disabled), .motor-filter-reset:focus-visible { border-color: #98a2b3; color: #344054; background: #f9fafb; }
    .motor-filter-reset:disabled { opacity: .45; cursor: default; }
    .motor-filter-list { display: flex; flex-wrap: wrap; gap: 20px 28px; align-items: flex-start; }
    .motor-filter { min-width: 180px; margin: 0; padding: 0; border: 0; }
    .motor-filter legend { margin-bottom: 8px; color: #475467; font-size: .82rem; font-weight: 650; }
    .motor-filter-controls { display: flex; flex-wrap: wrap; gap: 8px 14px; align-items: center; }
    .motor-filter-option { display: inline-flex; align-items: center; gap: 6px; cursor: pointer; }
    .motor-filter-option input { margin: 0; }
    .motor-select, .motor-date-range input { min-height: 36px; border: 1px solid #cbd2dc; border-radius: 7px; padding: 6px 9px; background: white; color: inherit; }
    .motor-multiselect-dropdown-controls { display: block; }
    .motor-multiselect-dropdown { box-sizing: border-box; position: relative; width: 240px; max-width: 100%; }
    .motor-multiselect-dropdown summary { box-sizing: border-box; min-height: 36px; border: 1px solid #cbd2dc; border-radius: 7px; padding: 7px 34px 7px 10px; background: white; cursor: pointer; list-style: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; position: relative; }
    .motor-multiselect-dropdown summary::-webkit-details-marker { display: none; }
    .motor-multiselect-dropdown summary::after { content: "▾"; position: absolute; right: 10px; color: #667085; }
    .motor-multiselect-dropdown[open] summary { border-radius: 7px 7px 0 0; }
    .motor-multiselect-dropdown[open] summary::after { content: "▴"; }
    .motor-multiselect-panel { box-sizing: border-box; position: absolute; z-index: 100; top: 100%; left: 0; width: 100%; border: 1px solid #cbd2dc; border-top: 0; border-radius: 0 0 7px 7px; padding: 8px; background: white; box-shadow: 0 10px 24px #17203324; }
    .motor-multiselect-dropdown.drop-up[open] summary { border-radius: 0 0 7px 7px; }
    .motor-multiselect-dropdown.drop-up .motor-multiselect-panel { top: auto; bottom: 100%; border-top: 1px solid #cbd2dc; border-bottom: 0; border-radius: 7px 7px 0 0; box-shadow: 0 -10px 24px #17203324; }
    .motor-multiselect-search { box-sizing: border-box; width: 100%; min-height: 34px; border: 1px solid #cbd2dc; border-radius: 6px; padding: 5px 8px; color: inherit; }
    .motor-multiselect-options { display: flex; flex-direction: column; gap: 7px; max-height: 220px; margin-top: 8px; overflow-y: auto; }
    .motor-multiselect-options .motor-filter-option { min-height: 24px; }
    .motor-multiselect-options .motor-filter-option[hidden] { display: none; }
    .motor-date-separator { color: #667085; }
    .motor-report-shell { display: grid; grid-template-columns: minmax(220px, 280px) minmax(0, 1fr); gap: 20px; align-items: start; }
    .motor-sidebar-container { box-sizing: border-box; position: sticky; top: 16px; min-width: 0; max-width: 100%; max-height: calc(100vh - 32px); overflow-x: hidden; overflow-y: auto; }
    .motor-sidebar-container > summary { display: none; }
    .motor-sidebar { display: grid; width: 100%; min-width: 0; gap: 12px; }
    .motor-sidebar-actions { display: flex; justify-content: flex-end; min-width: 0; }
    .motor-sidebar .motor-card { box-sizing: border-box; width: 100%; min-width: 0; margin: 0; }
    .motor-sidebar .motor-filter-list, .motor-sidebar .motor-filter, .motor-sidebar .motor-filter-controls { min-width: 0; max-width: 100%; }
    .motor-sidebar .motor-filter { width: 100%; }
    .motor-sidebar .motor-multiselect-dropdown { width: 100%; max-width: 100%; }
    .motor-text-body { margin: 0; white-space: pre-wrap; overflow-wrap: anywhere; line-height: 1.5; }
    .motor-report-content { min-width: 0; }
    .motor-tabs { min-width: 0; margin: 16px 0; }
    .motor-tab-list { display: flex; gap: 4px; overflow-x: auto; border-bottom: 1px solid #dce1e8; }
    .motor-tab-button { appearance: none; border: 0; border-bottom: 2px solid transparent; padding: 10px 14px; background: transparent; color: #667085; cursor: pointer; font: inherit; font-weight: 650; white-space: nowrap; }
    .motor-tab-button:hover { color: #344054; background: #f2f4f7; }
    .motor-tab-button[aria-selected="true"] { color: #172033; border-bottom-color: #3b6eea; }
    .motor-tab-button:focus-visible { outline: 2px solid #3b6eea; outline-offset: -2px; }
    .motor-tab-panel { min-width: 0; padding-top: 4px; }
    .motor-tab-panel[hidden] { display: none; }
    .motor-stale > * { opacity: .42; }
    .motor-loading::after { content: "Updating…"; position: absolute; inset: 12px 12px auto auto; padding: 5px 8px; border-radius: 6px; color: #475467; background: #f2f4f7; font-size: .75rem; font-weight: 650; opacity: 1; }
    .motor-chart.vega-embed { display: block; width: 100%; min-width: 0; }
    .motor-chart-shared-tooltip { position: fixed; z-index: 1000; min-width: 180px; max-width: min(560px, calc(100vw - 16px)); box-sizing: border-box; padding: 10px 12px; border: 1px solid #344054; border-radius: 8px; color: white; background: #172033f2; box-shadow: 0 8px 24px #10182840; pointer-events: none; font-size: .82rem; }
    .motor-chart-shared-tooltip[hidden] { display: none; }
    .motor-chart-shared-tooltip-heading { margin-bottom: 8px; color: #d0d5dd; font-weight: 650; }
    .motor-chart-shared-tooltip-table { width: 100%; border-collapse: collapse; }
    .motor-chart-shared-tooltip-table th, .motor-chart-shared-tooltip-table td { border: 0; padding: 4px 6px; font-size: inherit; line-height: 1.35; text-align: left; text-transform: none; }
    .motor-chart-shared-tooltip-table th { color: #98a2b3; font-weight: 650; }
    .motor-chart-shared-tooltip-table td { color: #f2f4f7; }
    .motor-chart-shared-tooltip-table .motor-chart-shared-tooltip-swatch-heading, .motor-chart-shared-tooltip-table .motor-chart-shared-tooltip-swatch-cell { width: 9px; padding-right: 0; }
    .motor-chart-shared-tooltip-table .motor-chart-shared-tooltip-value, .motor-chart-shared-tooltip-table .motor-chart-shared-tooltip-detail-value { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .motor-chart-shared-tooltip-table .motor-chart-shared-tooltip-label { max-width: 160px; }
    .motor-chart-shared-tooltip-table tr.is-hovered td { background: #ffffff20; }
    .motor-chart-shared-tooltip-table tr.is-muted { opacity: .62; }
    .motor-chart-shared-tooltip-table tr.is-hovered .motor-chart-shared-tooltip-swatch { box-shadow: 0 0 0 2px white; }
    .motor-chart-shared-tooltip-swatch { width: 9px; height: 9px; border-radius: 50%; background: #98a2b3; }
    .motor-chart-shared-tooltip-label { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .motor-chart-shared-tooltip-value { font-variant-numeric: tabular-nums; font-weight: 650; text-align: right; }
    .motor-row { display: grid; grid-template-columns: repeat(var(--motor-columns), minmax(0, 1fr)); gap: 16px; align-items: start; margin: 16px 0; }
    .motor-row > * { min-width: 0; }
    .motor-row > .motor-card { margin: 0; }
    .status-line { font-weight: 650; margin-bottom: 16px; }
    .warning { color: #8a5700; }
    dl { display: grid; grid-template-columns: max-content 1fr; gap: 8px 20px; margin: 0; }
    dt { color: #667085; }
    dd { margin: 0; overflow-wrap: anywhere; }
    ul { margin: 0; padding-left: 20px; }
    code { font-family: ui-monospace, monospace; font-size: .9em; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid #e6e9ee; padding: 10px 12px; text-align: left; }
    th { color: #667085; font-size: .8rem; text-transform: uppercase; }
    pre { white-space: pre-wrap; overflow-wrap: anywhere; }
    #motor-loading-status { background: white; border: 1px solid #dce1e8; border-radius: 12px; padding: 20px; }
    .motor-loading-status-title { color: #344054; font-weight: 650; }
    .motor-loading-status-summary { margin-top: 6px; color: #667085; font-size: .85rem; }
    .motor-loading-status-list { display: grid; gap: 4px; margin: 12px 0 0; padding-left: 20px; color: #667085; font-size: .82rem; }
    .motor-loading-status-step.is-running { color: #3538cd; }
    .motor-loading-status-step.is-failed { color: #b42318; }
    @media (min-width: 901px) {
      .motor-sidebar-container:not([open]) > .motor-sidebar { display: block; }
    }
    @media (max-width: 900px) {
      .motor-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .motor-row[data-count="1"] { grid-template-columns: minmax(0, 1fr); }
      .motor-report-shell { grid-template-columns: minmax(0, 1fr); }
      .motor-sidebar-container { position: static; max-height: none; overflow: visible; }
      .motor-sidebar-container > summary { display: block; padding: 12px 14px; border: 1px solid #dce1e8; border-radius: 8px; background: white; cursor: pointer; font-weight: 650; }
      .motor-sidebar-container[open] > summary { margin-bottom: 12px; }
    }
    @media (max-width: 600px) {
      .motor-row { grid-template-columns: minmax(0, 1fr); }
      .motor-filter-list, .motor-filter-controls { display: grid; grid-template-columns: minmax(0, 1fr); }
      .motor-filter { min-width: 0; }
      .motor-multiselect-dropdown { width: 100%; }
    }
  </style>
</head>
<body>
  <main id="motor-app">
    <h1>{{ manifest.report.title }}</h1>
    <section id="motor-loading-status" aria-live="polite">Loading embedded data…</section>
  </main>
  <script type="application/json" id="motor-manifest">{{ manifest_json | safe }}</script>
  <script type="application/json" id="motor-report-spec">{{ report_spec_json | safe }}</script>
  {% for source in sources %}
  <script type="application/octet-stream" id="motor-data-{{ source.passport.name }}" data-source-name="{{ source.passport.name }}" data-source-format="{{ source.passport.source_format }}" data-encoding="base64+gzip+{{ source.passport.source_format }}">{{ source.encoded_data }}</script>
  {% endfor %}
  <script type="application/octet-stream" id="motor-duckdb-wasm" data-encoding="base64+gzip+wasm">{{ duckdb_wasm }}</script>
  <script type="application/octet-stream" id="motor-duckdb-worker">{{ duckdb_worker }}</script>
  <script>{{ vega_js | safe }}</script>
  <script>{{ vega_lite_js | safe }}</script>
  <script>{{ vega_embed_js | safe }}</script>
  <script>{{ runtime_js | safe }}</script>
</body>
</html>
