<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ manifest.report.title }}</title>
  <style>
    :root { color-scheme: light; font-family: Inter, system-ui, sans-serif; color: #172033; background: #f6f7f9; }
    body { margin: 0; }
    main { max-width: 1120px; margin: 0 auto; padding: 48px 24px; }
    h1 { font-size: 2rem; margin: 0 0 24px; }
    h2 { font-size: 1rem; margin: 0 0 16px; }
    .motor-card { background: white; border: 1px solid #dce1e8; border-radius: 12px; padding: 20px; margin: 16px 0; box-shadow: 0 2px 8px #1720330a; overflow-x: auto; }
    .motor-component { position: relative; transition: opacity .15s ease; }
    .motor-component-error, .motor-fatal-error { color: #a11b1b; background: #fff4f4; border: 1px solid #f2b8b8; border-radius: 12px; padding: 20px; }
    .motor-version { color: #667085; font-family: ui-monospace, monospace; font-size: .8rem; margin: 12px 0; overflow-wrap: anywhere; }
    .motor-big-value { font-size: 2.25rem; font-weight: 700; }
    .motor-empty { color: #667085; margin: 0; }
    .motor-filter-list { display: flex; flex-wrap: wrap; gap: 20px 28px; align-items: flex-start; }
    .motor-filter { min-width: 180px; margin: 0; padding: 0; border: 0; }
    .motor-filter legend { margin-bottom: 8px; color: #475467; font-size: .82rem; font-weight: 650; }
    .motor-filter-controls { display: flex; flex-wrap: wrap; gap: 8px 14px; align-items: center; }
    .motor-filter-option { display: inline-flex; align-items: center; gap: 6px; cursor: pointer; }
    .motor-filter-option input { margin: 0; }
    .motor-select, .motor-date-range input { min-height: 36px; border: 1px solid #cbd2dc; border-radius: 7px; padding: 6px 9px; background: white; color: inherit; }
    .motor-date-separator { color: #667085; }
    .motor-stale > * { opacity: .42; }
    .motor-loading::after { content: "Updating…"; position: absolute; inset: 12px 12px auto auto; padding: 5px 8px; border-radius: 6px; color: #475467; background: #f2f4f7; font-size: .75rem; font-weight: 650; opacity: 1; }
    .motor-chart.vega-embed { display: block; width: 100%; min-width: 0; }
    .motor-row { display: grid; grid-template-columns: repeat(var(--motor-columns), minmax(0, 1fr)); gap: 16px; align-items: start; margin: 16px 0; }
    .motor-row > * { min-width: 0; }
    .motor-row > .motor-card { margin: 0; }
    .status-line { font-weight: 650; margin-bottom: 16px; }
    .warning { color: #8a5700; }
    dl { display: grid; grid-template-columns: max-content 1fr; gap: 8px 20px; margin: 0; }
    dt { color: #667085; }
    dd { margin: 0; overflow-wrap: anywhere; }
    ul { margin: 0; padding-left: 20px; }
    code { font-family: ui-monospace, monospace; font-size: .9em; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid #e6e9ee; padding: 10px 12px; text-align: left; }
    th { color: #667085; font-size: .8rem; text-transform: uppercase; }
    pre { white-space: pre-wrap; overflow-wrap: anywhere; }
    #motor-loading-status { background: white; border: 1px solid #dce1e8; border-radius: 12px; padding: 20px; }
    @media (max-width: 900px) {
      .motor-row { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .motor-row[data-count="1"] { grid-template-columns: minmax(0, 1fr); }
    }
    @media (max-width: 600px) {
      .motor-row { grid-template-columns: minmax(0, 1fr); }
      .motor-filter-list, .motor-filter-controls { display: grid; grid-template-columns: minmax(0, 1fr); }
      .motor-filter { min-width: 0; }
    }
  </style>
</head>
<body>
  <main id="motor-app">
    <h1>{{ manifest.report.title }}</h1>
    <section id="motor-loading-status" aria-live="polite">Loading embedded data…</section>
  </main>
  <script type="application/json" id="motor-manifest">{{ manifest_json | safe }}</script>
  <script type="application/json" id="motor-report-spec">{{ report_spec_json | safe }}</script>
  {% for source in sources %}
  <script type="application/octet-stream" id="motor-data-{{ source.passport.name }}" data-source-name="{{ source.passport.name }}" data-encoding="base64+gzip+csv">{{ source.encoded_data }}</script>
  {% endfor %}
  <script type="application/octet-stream" id="motor-duckdb-wasm" data-encoding="base64+gzip+wasm">{{ duckdb_wasm }}</script>
  <script type="application/octet-stream" id="motor-duckdb-worker">{{ duckdb_worker }}</script>
  <script>{{ vega_js | safe }}</script>
  <script>{{ vega_lite_js | safe }}</script>
  <script>{{ vega_embed_js | safe }}</script>
  <script>{{ runtime_js | safe }}</script>
</body>
</html>
